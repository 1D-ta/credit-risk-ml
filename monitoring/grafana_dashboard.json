{ "dashboard": { "title": "Credit Risk - Inference Metrics", "panels": [ { "type": "graph", "title": "Request Latency (p50/p95)", "targets": [{ "expr": "histogram_quantile(0.5, sum(rate(inference_request_latency_seconds_bucket[1m])) by (le))" }, { "expr": "histogram_quantile(0.95, sum(rate(inference_request_latency_seconds_bucket[1m])) by (le))" }] }, { "type": "graph", "title": "Request Volume", "targets": [{ "expr": "sum(rate(inference_requests_total[1m]))" }] }, { "type": "graph", "title": "Error Rate", "targets": [{ "expr": "sum(rate(inference_request_errors_total[1m])) / sum(rate(inference_requests_total[1m]))" }] }, { "type": "graph", "title": "Prediction PSI", "targets": [{ "expr": "model_prediction_psi" }] } ] } }
